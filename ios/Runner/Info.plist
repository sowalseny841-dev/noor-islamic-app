<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>fr</string>
    <key>CFBundleDisplayName</key>
    <string>Noor - نور</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Noor</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <!-- Catégorie App Store -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.reference</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- Permissions avec justifications détaillées -->
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Noor utilise votre localisation pour calculer avec précision les horaires de prière (Fajr, Dhuhr, Asr, Maghrib, Isha) selon votre position géographique et envoyer des rappels Azan.</string>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Noor utilise votre localisation pour calculer les horaires de prière précis selon votre ville.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>Noor utilise votre localisation en arrière-plan pour vous envoyer des rappels de prière à l'heure exacte.</string>

    <key>NSMotionUsageDescription</key>
    <string>Noor utilise les capteurs de mouvement pour afficher la direction de la Qibla (La Mecque) via la boussole.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>Noor peut utiliser le microphone pour enregistrer vos récitations du Coran à partager avec la communauté.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>Noor accède à vos photos pour vous permettre de partager des images dans la communauté Ummah.</string>

    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Noor peut sauvegarder des fonds d'écran islamiques dans votre galerie.</string>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
        <string>remote-notification</string>
        <string>background-processing</string>
    </array>

    <!-- Orientation uniquement portrait -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>api.alquran.cloud</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSExceptionMinimumTLSVersion</key>
                <string>TLSv1.2</string>
            </dict>
        </dict>
    </dict>

    <!-- Localisation -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>fr</string>
        <string>en</string>
        <string>ar</string>
    </array>
    <key>CFBundleDevelopmentRegion</key>
    <string>fr</string>
</dict>
</plist>
